From 0eeddcb29f30b472f1201a8352770823ecc2c3ea Mon Sep 17 00:00:00 2001
From: Xarblu <xarblu@protonmail.com>
Date: Mon, 23 Feb 2026 20:00:39 +0100
Subject: [PATCH 2/2] sched: re-add faults_disabled_mapping

Removed in 7.0 because bcachefs was the only consumer.
Just re-add it for now and let Kent figure this one out :p

Signed-off-by: Xarblu <xarblu@protonmail.com>
Link: https://lore.kernel.org/all/20260122085223.487092-1-hch@lst.de/
---
 include/linux/sched.h | 1 +
 init/init_task.c      | 1 +
 2 files changed, 2 insertions(+)

diff --git a/include/linux/sched.h b/include/linux/sched.h
index 074ad4ef3d81..3a1bd2ea090c 100644
--- a/include/linux/sched.h
+++ b/include/linux/sched.h
@@ -956,6 +956,7 @@ struct task_struct {
 
 	struct mm_struct		*mm;
 	struct mm_struct		*active_mm;
+	struct address_space		*faults_disabled_mapping;
 
 	int				exit_state;
 	int				exit_code;
diff --git a/init/init_task.c b/init/init_task.c
index 5c838757fc10..db92c404d59a 100644
--- a/init/init_task.c
+++ b/init/init_task.c
@@ -113,6 +113,7 @@ struct task_struct init_task __aligned(L1_CACHE_BYTES) = {
 	.nr_cpus_allowed= NR_CPUS,
 	.mm		= NULL,
 	.active_mm	= &init_mm,
+	.faults_disabled_mapping = NULL,
 	.restart_block	= {
 		.fn = do_no_restart_syscall,
 	},
-- 
2.53.0

